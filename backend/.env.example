# Backend configuration -- copy to .env and edit as needed.

# Port the Express server listens on. Defaults to 3001.
PORT=3001

# Path to the SQLite database file. Defaults to ./data/sbg-tracker.db relative to the backend folder.
# Use ":memory:" for an in-memory database (useful in tests).
DATABASE_PATH=./data/sbg-tracker.db

# Comma-separated list of allowed CORS origins. Use "*" for any origin (dev only).
# Example: CORS_ORIGINS=http://localhost:5173,https://username.github.io
CORS_ORIGINS=*

# Static directory to serve as the frontend, relative to the backend folder.
# Set to empty string to disable static serving (useful when frontend is hosted separately, e.g. GitHub Pages).
STATIC_DIR=../frontend
