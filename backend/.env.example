# Backend configuration -- copy to .env and edit as needed.

# Port the Express server listens on. Defaults to 3001.
PORT=3001

# Path to the SQLite database file. Defaults to ./data/sbg-tracker.db relative to the backend folder.
# Use ":memory:" for an in-memory database (useful in tests).
DATABASE_PATH=./data/sbg-tracker.db

# Comma-separated list of allowed CORS origins. Use "*" for any origin (dev only).
# Example: CORS_ORIGINS=http://localhost:5173,https://username.github.io
CORS_ORIGINS=*

# Static directory to serve as the frontend, relative to the backend folder.
# Set to empty string to disable static serving (useful when frontend is hosted separately, e.g. GitHub Pages).
STATIC_DIR=../frontend

# --- AI features (Phase 4: scope extraction, more coming) ---
# Required for /api/ai/* endpoints. Get a key at https://console.anthropic.com.
# Each PDF extraction costs ~$0.10-0.20 with Claude Sonnet.
ANTHROPIC_API_KEY=
# Override the model if needed. Default: claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Set to 1 in tests to use a deterministic stub instead of calling Claude.
# ANTHROPIC_FAKE=0

# --- Sub bid email intake ---
# Forward sub bid PDFs to a dedicated mailbox/alias, then the backend can poll
# it and append parsed rows to the active project's Sub Bid Inbox.
#
# Generic IMAP works for Microsoft 365, Google Workspace, and most hosted mail
# providers when IMAP/app-password access is enabled.
BID_INTAKE_IMAP_HOST=
BID_INTAKE_IMAP_PORT=993
BID_INTAKE_IMAP_TLS=true
BID_INTAKE_IMAP_USER=bids@sourcebuild.net
BID_INTAKE_IMAP_PASSWORD=
BID_INTAKE_IMAP_MAILBOX=INBOX

# Optional: move processed messages after import. Leave blank to keep them in
# the inbox and mark them seen.
# BID_INTAKE_PROCESSED_MAILBOX=Processed

# Default true. Set false if you need to re-scan seen messages for testing.
# BID_INTAKE_ONLY_UNSEEN=true

# Optional auto-poller. Manual "Check Inbox" from the project view works without
# this. Auto-poll requires each message subject to include [SBG:<projectId>] or
# BID_INTAKE_DEFAULT_PROJECT_ID to be set.
# BID_INTAKE_AUTO_POLL=0
# BID_INTAKE_POLL_SECONDS=300
# BID_INTAKE_DEFAULT_PROJECT_ID=
